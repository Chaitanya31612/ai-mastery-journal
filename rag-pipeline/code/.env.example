# ============================================================================
# RAG Pipeline — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your API keys.
#
# The pipeline will automatically load these from .env when you run:
#   python -m code.main query "your question"
# ============================================================================

# Groq API key (for LLM generation)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (alternative LLM provider)
# Get yours at: https://ai.google.dev/
GOOGLE_API_KEY=your_google_api_key_here

# Ollama doesn't need an API key — just run the server locally
# OLLAMA_BASE_URL=http://localhost:11434
